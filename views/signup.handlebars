<section class="dashboard-hero">
  <h1>Create Your BikeSafe NYC Account</h1>
  <p class="subtext">Sign up to report stolen bikes, comment on missing bike posts, and save favorite parking locations.</p>
</section>

<section class="dashboard-section">
  <div class="auth-card">
    {{#if error}}
      <div class="error-message">{{error}}</div>
    {{/if}}

    <form id="signupForm" action="/signup" method="POST" class="auth-form">
      <label for="firstName">First Name</label>
      <input id="firstName" name="firstName" type="text" value="{{formData.firstName}}">

      <label for="lastName">Last Name</label>
      <input id="lastName" name="lastName" type="text" value="{{formData.lastName}}">

      <label for="username">Username</label>
      <input id="username" name="username" type="text" value="{{formData.username}}">

      <label for="email">Email</label>
      <input id="email" name="email" type="email" value="{{formData.email}}">

      <label for="password">Password</label>
      <input id="password" name="password" type="password">

      <label for="confirmPassword">Confirm Password</label>
      <input id="confirmPassword" name="confirmPassword" type="password">

      <div class="auth-actions">
        <button type="submit" class="btn">Sign Up</button>
        <a href="/login" class="auth-link">Already have an account?</a>
      </div>
    </form>
  </div>
</section>
