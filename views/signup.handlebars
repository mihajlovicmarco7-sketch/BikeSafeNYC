<h1>Create Your BikeSafe NYC Account</h1>

{{#if error}}
  <p class="error">{{error}}</p>
{{/if}}

<form id="signupForm" action="/signup" method="POST">
  <label for="firstName">First Name</label>
  <input id="firstName" name="firstName" type="text" value="{{formData.firstName}}">

  <label for="lastName">Last Name</label>
  <input id="lastName" name="lastName" type="text" value="{{formData.lastName}}">

  <label for="username">Username</label>
  <input id="username" name="username" type="text" value="{{formData.username}}">

  <label for="email">Email</label>
  <input id="email" name="email" type="email" value="{{formData.email}}">

  <label for="password">Password</label>
  <input id="password" name="password" type="password">

  <label for="confirmPassword">Confirm Password</label>
  <input id="confirmPassword" name="confirmPassword" type="password">

  <button type="submit">Sign Up</button>
</form>

<p>Already have an account? <a href="/login">Log in</a></p>

<script src="/public/js/authValidation.js"></script>