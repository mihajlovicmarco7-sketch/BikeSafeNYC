<section class="dashboard-hero">
  <h1>Login to BikeSafe NYC</h1>
  <p class="subtext">Log in to manage reports, comment on missing bike posts, and access your saved locations.</p>
</section>

<section class="dashboard-section">
  <div class="auth-card">
    {{#if error}}
      <div class="error-message">{{error}}</div>
    {{/if}}

    <form id="loginForm" action="/login" method="POST" class="auth-form">
      <label for="identifier">Username or Email</label>
      <input id="identifier" name="identifier" type="text" value="{{formData.identifier}}">

      <label for="password">Password</label>
      <input id="password" name="password" type="password">

      <div class="auth-actions">
        <button type="submit" class="btn">Login</button>
        <a href="/signup" class="auth-link">Need an account?</a>
      </div>
    </form>
  </div>
</section>